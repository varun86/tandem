{
  "name": "tandem",
  "private": true,
  "version": "0.4.12",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev:clean": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Get-Process | Where-Object { $_.ProcessName -in @('tandem','tandem-engine','node') } | Stop-Process -Force -ErrorAction SilentlyContinue; pnpm tauri dev\"",
    "engine:stop:windows": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Get-Process | Where-Object { $_.ProcessName -in @('tandem-engine','tandem','tandem-tui') } | Stop-Process -Force -ErrorAction SilentlyContinue\"",
    "engine:build": "cargo build -p tandem-ai",
    "engine:knowledge:bundle": "node scripts/generate-engine-knowledge-bundle.mjs",
    "engine:knowledge:test": "node --test scripts/engine-knowledge-bundle.test.mjs",
    "engine:knowledge:verify": "node scripts/verify-engine-knowledge-bundle.mjs",
    "engine:start": "cargo run -p tandem-ai --bin tandem-engine -- serve --host 127.0.0.1 --port 39731",
    "engine:test": "cargo test -p tandem-server -p tandem-core -p tandem-ai",
    "test:blackboard": "rm -rf .tmp/ts-tests && tsc -p tsconfig.tests.json && node --test .tmp/ts-tests/*.test.js",
    "engine:smoke:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/engine_smoke.ps1",
    "engine:smoke:unix": "bash ./scripts/engine_smoke.sh",
    "docs:parity": "node scripts/verify-docs-parity.mjs",
    "i18n:parity": "node scripts/verify-i18n-parity.mjs",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "check-secrets": "node scripts/check-secrets.js",
    "download-sidecar": "node scripts/download-sidecar.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "i18next": "^25.8.20",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-diff-viewer-continued": "^4.2.0",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "react-window": "^2.2.7",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  "lint-staged": {
    "guide/src/content/docs/**/*.{md,mdx}": [
      "node scripts/generate-engine-knowledge-bundle.mjs",
      "git add engine/resources/default_knowledge_bundle.json engine/resources/default_knowledge_manifest.json"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "node scripts/check-secrets.js"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.rs": [
      "rustfmt --edition 2021",
      "node scripts/check-secrets.js"
    ]
  }
}
