TANDEM_BASE_URL=http://127.0.0.1:39731
TANDEM_API_TOKEN=

# Objective passed to manager if not provided as argv.
SWARM_OBJECTIVE=Prepare and ship a small feature with tests and review
SWARM_MAX_TASKS=3

# Repo metadata for PR checks in health routine.
SWARM_GITHUB_OWNER=
SWARM_GITHUB_REPO=

# Required for routine Telegram summaries.
TANDEM_SWARM_TELEGRAM_CHAT_ID=

# Existing Telegram bot token (same token your Tandem Telegram adapter uses).
TANDEM_TELEGRAM_BOT_TOKEN=
