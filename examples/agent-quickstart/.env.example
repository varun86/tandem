# Tandem engine URL (defaults to localhost when running on same machine)
TANDEM_ENGINE_URL=http://127.0.0.1:39731

# Secret token to protect the portal. Set to a long random string.
# Generate one: openssl rand -base64 32
PORTAL_KEY=change-me-to-a-secure-token

# Port for the Express server (production mode)
PORT=3030

# For local Vite dev server — engine proxy target:
VITE_TANDEM_ENGINE_URL=http://127.0.0.1:39731
