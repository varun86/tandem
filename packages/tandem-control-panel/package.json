{
  "name": "@frumu/tandem-panel",
  "version": "0.3.28",
  "description": "Full web control center for Tandem Engine (chat, routines, swarm, memory, channels, and ops)",
  "type": "module",
  "bin": {
    "tandem-control-panel": "bin/setup.js",
    "tandem-setup": "bin/setup.js",
    "tandem-control-panel-init": "bin/init-env.js"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "test:smoke": "node --test tests/smoke.test.mjs",
    "init:env": "node bin/init-env.js",
    "prepublishOnly": "npm run build",
    "start": "node bin/setup.js",
    "mcp:catalog:refresh": "node ../../scripts/generate-mcp-catalog.mjs"
  },
  "files": [
    "bin",
    "dist",
    ".env.example",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frumu-ai/tandem.git"
  },
  "homepage": "https://tandem.frumu.ai",
  "author": "Frumu Ltd",
  "dependencies": {
    "@frumu/tandem": "^0.3.25",
    "@frumu/tandem-client": "^0.3.25",
    "lucide": "^0.575.0",
    "motion": "^11.18.2"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^7.0.4"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "tandem",
    "agent",
    "engine",
    "control-panel",
    "setup"
  ],
  "license": "MIT OR Apache-2.0",
  "publishConfig": {
    "access": "public"
  }
}
