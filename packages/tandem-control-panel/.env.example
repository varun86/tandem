# Control panel bind port
TANDEM_CONTROL_PANEL_PORT=39732

# Tip: run `tandem-setup init` to auto-generate this file and token.

# Control panel bind host (loopback by default)
TANDEM_CONTROL_PANEL_HOST=127.0.0.1

# Optional externally reachable URL for future pairing / gateway flows
TANDEM_CONTROL_PANEL_PUBLIC_URL=

# Full engine URL (preferred)
TANDEM_ENGINE_URL=http://127.0.0.1:39731

# Optional engine host/port fallback (used when TANDEM_ENGINE_URL is not set)
TANDEM_ENGINE_HOST=127.0.0.1
TANDEM_ENGINE_PORT=39731

# Auto-start local engine if not running (1=yes, 0=no)
TANDEM_CONTROL_PANEL_AUTO_START_ENGINE=1

# Canonical state roots for official bootstrap installs
TANDEM_STATE_DIR=
TANDEM_CONTROL_PANEL_STATE_DIR=

# Engine API token used when control panel auto-starts a local engine.
# If unset, the panel generates one at startup and prints it in logs.
TANDEM_CONTROL_PANEL_ENGINE_TOKEN=tk_change_me

# Disable per-run guard budgets by default (1=yes, 0=no)
TANDEM_DISABLE_TOOL_GUARD_BUDGETS=1
TANDEM_TOOL_ROUTER_ENABLED=0
TANDEM_PROMPT_CONTEXT_HOOK_TIMEOUT_MS=5000
TANDEM_PROVIDER_STREAM_CONNECT_TIMEOUT_MS=30000
TANDEM_PROVIDER_STREAM_IDLE_TIMEOUT_MS=90000
TANDEM_PERMISSION_WAIT_TIMEOUT_MS=15000
TANDEM_TOOL_EXEC_TIMEOUT_MS=45000
TANDEM_BASH_TIMEOUT_MS=30000

# Built-in websearch defaults. `auto` can try configured backends in order
# (managed Tandem URL, SearxNG, Brave, Exa) before falling back.
TANDEM_SEARCH_BACKEND=auto
TANDEM_SEARCH_URL=https://search.tandem.frumu.ai
TANDEM_SEARCH_TIMEOUT_MS=10000
# Optional direct-provider overrides
# TANDEM_BRAVE_SEARCH_API_KEY=
# TANDEM_EXA_API_KEY=
# TANDEM_SEARXNG_URL=http://127.0.0.1:8080

# Bug Monitor (disabled by default)
# TANDEM_BUG_MONITOR_ENABLED=0
# TANDEM_BUG_MONITOR_REPO=owner/repo
# TANDEM_BUG_MONITOR_MCP_SERVER=github
# TANDEM_BUG_MONITOR_PROVIDER_PREFERENCE=auto
# TANDEM_BUG_MONITOR_PROVIDER_ID=openrouter
# TANDEM_BUG_MONITOR_MODEL_ID=openai/gpt-4.1-mini
# Optional global duplicate-signature retry limit for tool calls.
# TANDEM_TOOL_LOOP_DUPLICATE_SIGNATURE_LIMIT=200

# Optional caps when guard budgets are enabled
# TANDEM_TOOL_BUDGET_DEFAULT=10
# TANDEM_TOOL_BUDGET_BATCH=10
# TANDEM_TOOL_BUDGET_WEBSEARCH=8
# TANDEM_TOOL_BUDGET_READ=8
# TANDEM_TOOL_BUDGET_SEARCH=6
# TANDEM_TOOL_BUDGET_GLOB=4

# Back-compat alias also respected for auto-started engines.
# TANDEM_API_TOKEN=tk_change_me

# Session TTL in minutes
TANDEM_CONTROL_PANEL_SESSION_TTL_MINUTES=1440

# ─── ACA Integration ─────────────────────────────────────────────────
# Optional external ACA base URL. Leave blank to disable ACA integration.
# When set, the control panel probes this URL on startup and exposes it via
# /api/capabilities as aca_integration.
# Example: ACA_BASE_URL=http://127.0.0.1:39735
ACA_BASE_URL=

# ACA bearer token. Required for ACA project, run, and log APIs.
# If both ACA_API_TOKEN and ACA_API_TOKEN_FILE are set, ACA_API_TOKEN wins.
ACA_API_TOKEN=

# Optional path to a file containing the ACA bearer token.
ACA_API_TOKEN_FILE=

# Path on ACA_BASE_URL to use for health/status probe (default: /health)
ACA_HEALTH_PATH=/health

# Probe timeout in milliseconds. Probes that take longer return "aca_probe_timeout".
ACA_PROBE_TIMEOUT_MS=5000

# How long to cache capability probe results, in milliseconds (default: 45000 = 45 s).
# Set lower for faster ACA availability detection, higher to reduce probe frequency.
ACA_CAPABILITY_CACHE_TTL_MS=45000
